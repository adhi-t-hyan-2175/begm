# ─────────────────────────────────────────────────────────────
#  BACKEND — Environment Variables Template
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Supabase Project URL (Settings → API)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase Service Role Key — KEEP SECRET (Settings → API → service_role)
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY

# App Secret
JWT_SECRET=change_this_to_a_random_secure_string
PORT=5000

# Admin auto-promotion
# Set to the Google email address that should receive admin access on first login
ADMIN_EMAIL=your_admin_email@gmail.com

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Razorpay (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_KEY_SECRET
