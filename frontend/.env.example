# ─────────────────────────────────────────────────────────────
#  FRONTEND — Environment Variables Template
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Backend API URL (use your Render/Railway URL in production)
VITE_API_URL=http://localhost:5000

# Supabase (Settings → API → anon public key)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Razorpay public key (safe to expose — this is the publishable key)
VITE_RAZORPAY_KEY=rzp_test_YOUR_KEY_ID

# App URL (used for referral links)
VITE_APP_URL=http://localhost:5173
